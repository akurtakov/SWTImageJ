<project>
  <modelVersion>4.0.0</modelVersion>
  <groupId>org.eclipse.swt.imagej</groupId>
  <artifactId>org.eclipse.swt.imagej.fatjar</artifactId>
  <version>1.5.0-SNAPSHOT</version>
  <packaging>jar</packaging>
<!-- Calculated from the bash script - Simply copy and paste the result in the properties section here! -->
  <properties>
  <eclipse.home>/Applications/Eclipse.app/Contents/Eclipse</eclipse.home>
  <core.commands.suffix>_3.12.300.v20241229-1638</core.commands.suffix>
  <core.runtime.suffix>_3.33.0.v20250206-0919</core.runtime.suffix>
  <equinox.common.suffix>_3.20.0.v20250129-1348</equinox.common.suffix>
  <jface.suffix>_3.36.0.v20250129-1243</jface.suffix>
  <jface.text.suffix>_3.27.0.v20250211-0938</jface.text.suffix>
  <text.suffix>_3.14.300.v20250119-1501</text.suffix>
  <osgi.suffix>_3.23.0.v20250228-0640</osgi.suffix>
  <swt.suffix>_3.129.0.v20250221-1734</swt.suffix>
