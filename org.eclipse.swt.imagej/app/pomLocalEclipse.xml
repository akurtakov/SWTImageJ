  <!-- org.eclipse.swt.gtk.linux.x86_64 not found (swt.gtk.suffix) -->
  <!-- org.eclipse.swt.cocoa.macosx.x86_64 not found (swt.cocoa.x86_64.suffix) -->
  <swt.cocoa.aarch64.suffix>_3.129.0.v20250221-1734</swt.cocoa.aarch64.suffix>
</properties>


  <dependencies>
    <!-- Your main project dependency -->
    <dependency>
      <groupId>org.eclipse.swt.imagej</groupId>
      <artifactId>org.eclipse.swt.imagej</artifactId>
      <version>1.5.0-SNAPSHOT</version>
    </dependency>
    <!-- Eclipse libraries for 4.35 (use property for version/timestamp) -->
    <dependency>
      <groupId>org.eclipse</groupId>
      <artifactId>org.eclipse.core.commands</artifactId>
      <version>3.12.400</version>
      <scope>system</scope>
      <systemPath>${eclipse.home}/plugins/org.eclipse.core.commands${core.commands.suffix}.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>org.eclipse</groupId>
      <artifactId>org.eclipse.core.runtime</artifactId>
      <version>3.33.0</version>
      <scope>system</scope>
      <systemPath>${eclipse.home}/plugins/org.eclipse.core.runtime${core.runtime.suffix}.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>org.eclipse</groupId>
      <artifactId>org.eclipse.equinox.common</artifactId>
      <version>3.21.0</version>
      <scope>system</scope>
      <systemPath>${eclipse.home}/plugins/org.eclipse.equinox.common${equinox.common.suffix}.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>org.eclipse</groupId>
      <artifactId>org.eclipse.jface</artifactId>
      <version>3.35.0</version>
      <scope>system</scope>
      <systemPath>${eclipse.home}/plugins/org.eclipse.jface${jface.suffix}.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>org.eclipse</groupId>
      <artifactId>org.eclipse.jface.text</artifactId>
      <version>3.27.0</version>
      <scope>system</scope>
      <systemPath>${eclipse.home}/plugins/org.eclipse.jface.text${jface.text.suffix}.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>org.eclipse</groupId>
      <artifactId>org.eclipse.text</artifactId>
      <version>3.14.300</version>
      <scope>system</scope>
      <systemPath>${eclipse.home}/plugins/org.eclipse.text${text.suffix}.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>org.eclipse</groupId>
      <artifactId>org.eclipse.osgi</artifactId>
      <version>3.22.0</version>
      <scope>system</scope>
      <systemPath>${eclipse.home}/plugins/org.eclipse.osgi${osgi.suffix}.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>org.eclipse</groupId>
      <artifactId>org.eclipse.swt</artifactId>
      <version>3.129.0</version>
      <scope>system</scope>
      <systemPath>${eclipse.home}/plugins/org.eclipse.swt${swt.suffix}.jar</systemPath>
    </dependency>
  </dependencies>
  <profiles>
    <profile>
      <id>windows</id>
      <activation>
        <os><family>Windows</family></os>
      </activation>
      <dependencies>
        <dependency>
          <groupId>org.eclipse</groupId>
          <artifactId>org.eclipse.swt.win32</artifactId>
          <version>3.129.0</version>
          <scope>system</scope>
          <systemPath>${eclipse.home}/plugins/org.eclipse.swt.win32.win32.x86_64${swt.win32.suffix}.jar</systemPath>
        </dependency>
      </dependencies>
    </profile>
    <profile>
      <id>linux</id>
      <activation>
         <os>
      		<name>Linux</name>
   		 </os>
      </activation>
      <dependencies>
        <dependency>
          <groupId>org.eclipse</groupId>
          <artifactId>org.eclipse.swt.gtk</artifactId>
          <version>3.129.0</version>
          <scope>system</scope>
          <systemPath>${eclipse.home}/plugins/org.eclipse.swt.gtk.linux.x86_64${swt.gtk.suffix}.jar</systemPath>
        </dependency>
      </dependencies>
    </profile>
    <profile>
      <id>mac-x86_64</id>
      <activation>
        <os>
          <family>mac</family>
          <arch>x86_64</arch>
        </os>
      </activation>
      <dependencies>
        <dependency>
          <groupId>org.eclipse</groupId>
          <artifactId>org.eclipse.swt.cocoa</artifactId>
          <version>3.129.0</version>
          <scope>system</scope>
          <systemPath>${eclipse.home}/plugins/org.eclipse.swt.cocoa.macosx.x86_64${swt.cocoa.x86_64.suffix}.jar</systemPath>
        </dependency>
      </dependencies>
    </profile>
    <profile>
      <id>mac-aarch64</id>
      <activation>
        <os>
          <family>mac</family>
          <arch>aarch64</arch>
        </os>
      </activation>
      <dependencies>
        <dependency>
          <groupId>org.eclipse</groupId>
          <artifactId>org.eclipse.swt.cocoa</artifactId>
          <version>3.129.0</version>
          <scope>system</scope>
          <systemPath>${eclipse.home}/plugins/org.eclipse.swt.cocoa.macosx.aarch64${swt.cocoa.aarch64.suffix}.jar</systemPath>
        </dependency>
      </dependencies>
    </profile>
  </profiles>

  <build>
  <!-- Package all required ImageJ folders and files in the exported *.jar! -->
  	<sourceDirectory>${project.basedir}</sourceDirectory>
   <resources>
			<resource>
				<directory>${project.basedir}</directory>
				<includes>
					<include>IJ_Props.txt</include>
				</includes>
			</resource>
			<resource>
				<directory>${project.basedir}/images</directory>
			</resource>
			<resource>
				<directory>${project.basedir}/macros</directory>
				<targetPath>macros</targetPath>
			</resource>
			<resource>
				<directory>${project.basedir}/plugins</directory>
				<targetPath>ij/plugin</targetPath>
				<includes>
					<include>**/*.class</include>
				</includes>
			</resource>
		</resources>
   <plugins>
    <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <createDependencyReducedPom>false</createDependencyReducedPom>
              <includeSystemScope>true</includeSystemScope>
              <filters>
              <filter>
                <artifact>*:*</artifact>
                <!-- Exclude the Eclipse plugin Manifest! -->
                <excludes>
                  <exclude>META-INF/MANIFEST.MF</exclude>
                  <!-- You can add more exclusions here if needed -->
                </excludes>
              </filter>
            </filters>
              <shadedClassifierName>fat</shadedClassifierName>
              <transformers>
                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                  <manifestEntries>
                  <Main-Class>ij.ImageJ</Main-Class>
                  <!-- Add all Eclipse/SWT libraries! -->
                  <Class-Path>libs/org.eclipse.core.commands-3.12.400.jar libs/org.eclipse.core.runtime-3.33.0.jar libs/org.eclipse.equinox.common-3.21.0.jar libs/org.eclipse.jface.text-3.27.0.jar libs/org.eclipse.text-3.14.300.jar libs/org.eclipse.jface-3.35.0.jar libs/org.eclipse.osgi-3.22.0.jar libs/org.eclipse.swt.cocoa-3.129.0.jar libs/org.eclipse.swt-3.129.0.jar</Class-Path>
                  </manifestEntries>
                </transformer>
              </transformers>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
    <groupId>org.apache.maven.plugins</groupId>
    <artifactId>maven-dependency-plugin</artifactId>
    <executions>
      <execution>
      <!-- Copy all Eclipse/SWT libraries to the export location! -->
        <id>copy-dependencies</id>
        <phase>package</phase>
        <goals>
          <goal>copy-dependencies</goal>
        </goals>
        <configuration>
          <outputDirectory>${project.build.directory}/libs</outputDirectory>
          <overWriteReleases>false</overWriteReleases>
          <overWriteSnapshots>true</overWriteSnapshots>
        </configuration>
      </execution>
    </executions>
  </plugin>
  </plugins>
  </build>
  
</project>